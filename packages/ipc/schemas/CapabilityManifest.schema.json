{
  "$ref": "#/definitions/CapabilityManifest",
  "definitions": {
    "CapabilityManifest": {
      "type": "object",
      "properties": {
        "protocolVersion": {
          "type": "string"
        },
        "kernelVersion": {
          "type": "string"
        },
        "kernelFineTuned": {
          "type": "boolean"
        },
        "supportedOperations": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "classify_store",
              "score_salience",
              "detect_conflict",
              "check_neighborhood_consistency",
              "deduplicate",
              "extract_atomic_facts",
              "link_intention_to_memories",
              "generate_retrieval_query",
              "rerank",
              "reject_low_confidence",
              "consolidate_cluster",
              "update_activation_weights",
              "update_citation_rates",
              "generate_simulation_seeds",
              "score_promotion",
              "resolve_conflict"
            ]
          }
        },
        "sleepState": {
          "type": "string",
          "enum": [
            "WAKE",
            "MICRO_SLEEP",
            "FULL_SLEEP",
            "SUPERVISED_PAUSE"
          ]
        },
        "memoryCounts": {
          "type": "object",
          "properties": {
            "episodic": {
              "type": "integer",
              "minimum": 0
            },
            "semanticNodes": {
              "type": "integer",
              "minimum": 0
            },
            "semanticEdges": {
              "type": "integer",
              "minimum": 0
            },
            "proceduralSkills": {
              "type": "integer",
              "minimum": 0
            },
            "intentions": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "episodic",
            "semanticNodes",
            "semanticEdges",
            "proceduralSkills",
            "intentions"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "protocolVersion",
        "kernelVersion",
        "kernelFineTuned",
        "supportedOperations",
        "sleepState",
        "memoryCounts"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}