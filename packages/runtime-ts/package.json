{
  "name": "@somnicortex/runtime",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "somnicortex-create-agent": "dist/src/cli/create-agent.js",
    "somnicortex-send-task": "dist/src/cli/send-task.js",
    "somnicortex-inspect-agent": "dist/src/cli/inspect-agent.js",
    "somnicortex-approve": "dist/src/cli/approve.js",
    "somnicortex-bootstrap-kernel": "dist/src/cli/bootstrap-kernel.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm build && node --test dist/tests/*.test.js",
    "test:integration": "pnpm build && node --test dist/tests/integration/*.test.js",
    "test:perf": "pnpm build && node --test dist/tests/performance-smoke.test.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "echo \"format handled externally\""
  },
  "dependencies": {
    "@somnicortex/ipc": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "pino": "^9.6.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
